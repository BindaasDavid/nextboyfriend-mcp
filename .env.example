# Place this file in the repo root (next to package.json). The server loads it via PROJECT_ROOT
# even when the process cwd is not the repo. For Cursor MCP you can duplicate keys in the MCP "env" block.
# https://docs.social-api.ai/
# One key for all SocialAPI features (accounts, posts to TikTok/IG/etc.). No separate TikTok API key.
SOCAPI_KEY=sapi_key_replace_me

# Optional alias (same value as SOCAPI_KEY if you prefer this name):
# SOCIAL_API_KEY=sapi_key_legacy_name_also_accepted
# SOCAPI_BASE_URL=https://api.social-api.ai/v1

# generate_posting_plan (Claude)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# If the public site is headless, set the WordPress origin that exposes /wp-json/
# WORDPRESS_API_BASE=https://cms.example.com

# YouTube Atom feed (channel_id). Search-based RSS returns HTTP 400 from YouTube.
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HeyGen (create_heygen_reel, check_heygen_status) — https://docs.heygen.com/
# HEYGEN_API_KEY=

# Supabase — editorial review (`list_supabase_articles`, `review_supabase_articles`)
# Default project URL resolves to …/rest/v1/articles on whkenlpvrcaztgmvkusa.supabase.co
# SUPABASE_URL=https://whkenlpvrcaztgmvkusa.supabase.co
# Or set the full REST URL:
# SUPABASE_ARTICLES_REST_URL=https://whkenlpvrcaztgmvkusa.supabase.co/rest/v1/articles
# SUPABASE_ANON_KEY=eyJ...
# Optional (bypasses RLS for server-side jobs; keep secret):
# SUPABASE_SERVICE_ROLE_KEY=

# --- GitHub Actions: TikTok automation (`npm run automate` / MCP Run workflow) ---
# Required for posting: SocialAPI TikTok account id (from dashboard or list_accounts).
# AUTOMATION_TIKTOK_ACCOUNT_ID=
# Optional: set to true to log payload without POSTing
# AUTOMATION_DRY_RUN=false
# AUTOMATION_HARVEST_LIMIT=8
# AUTOMATION_TRENDS_GEO=US
# AUTOMATION_CONTENT_SEED=optional-string-for-article-rotation
# If SocialAPI rejects external image URLs, set false to post text-only (caption + hashtags).
# AUTOMATION_INCLUDE_MEDIA_URLS=true
