# Place this file in the repo root (next to package.json). The server loads it via PROJECT_ROOT
# even when the process cwd is not the repo. For Cursor MCP you can duplicate keys in the MCP "env" block.
# https://docs.social-api.ai/
# One key for all SocialAPI features (accounts, posts to TikTok/IG/etc.). No separate TikTok API key.
SOCAPI_KEY=sapi_key_replace_me

# Optional alias (same value as SOCAPI_KEY if you prefer this name):
# SOCIAL_API_KEY=sapi_key_legacy_name_also_accepted
# SOCAPI_BASE_URL=https://api.social-api.ai/v1

# generate_posting_plan + MCP tools (Claude) — key must belong to an account with API credits
# ANTHROPIC_API_KEY=
# MCP default model if unset: Sonnet 4 — override e.g. claude-haiku-4-5-20251001 to save cost everywhere
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Social automation only (cheaper default: Haiku 4.5). Falls back to ANTHROPIC_MODEL if unset.
# AUTOMATION_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Article harvest for fetch_articles + social automation (Supabase `articles` table only)

# YouTube Atom feed (channel_id). Search-based RSS returns HTTP 400 from YouTube.
# YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HeyGen — https://docs.heygen.com/
# HEYGEN_API_KEY=
# In GitHub Actions: add the same key under Repository secrets → HEYGEN_API_KEY (runners do not load .env). 401 Unauthorized = wrong/expired key or extra quotes/spaces.
# When TikTok is in AUTOMATION_CHANNELS and AUTOMATION_INCLUDE_MEDIA_URLS is on, video is always HeyGen (avatar TTS from avatar_script). No Pollinations fallback for TikTok.
# Output size: default 720×1280 (9:16) to keep MP4 small. SocialAPI /media/upload can return 413 if the file is too large — we re-encode with ffmpeg before upload unless skipped below.
# AUTOMATION_HEYGEN_WIDTH=720
# AUTOMATION_HEYGEN_HEIGHT=1280
# AUTOMATION_SKIP_HEYGEN_REENCODE=false
# Background: default warm hex (not stark white). Or set AUTOMATION_HEYGEN_BG_IMAGE_URL to a public https image (cozy room, soft gradient) — HeyGen composites the avatar on top.
# AUTOMATION_HEYGEN_BG_COLOR=#E8E0D4
# AUTOMATION_HEYGEN_BG_IMAGE_URL=
# Voice: 0.5–1.5; Friendly/Soothing often sound less “AI”. Set AUTOMATION_HEYGEN_VOICE_EMOTION=none to omit emotion.
# AUTOMATION_HEYGEN_VOICE_SPEED=0.96
# AUTOMATION_HEYGEN_VOICE_EMOTION=Friendly
# Try Avatar IV only if your avatar supports it in HeyGen (errors → leave false).
# AUTOMATION_HEYGEN_USE_AVATAR_IV=false
# AUTOMATION_HEYGEN_AVATAR_ID=Daisy-inskirt-20220818
# AUTOMATION_HEYGEN_VOICE_ID=1bd001e7e50f421d891986aad5158bc8

# Supabase — harvest + editorial tools (`articles` table)
# Use full URL with https:// (host-only breaks fetch). Optional: SUPABASE_ARTICLES_REST_URL=https://…/rest/v1/articles
# SUPABASE_URL=https://whkenlpvrcaztgmvkusa.supabase.co
# SUPABASE_ANON_KEY=eyJ...   # never commit real keys; rotate if exposed
# SUPABASE_SERVICE_ROLE_KEY=  # optional; server-side only
# Harvest defaults match PostgREST: published rows, select columns, newest first
# SUPABASE_ARTICLES_SELECT=id,title,slug,category,created_at,source_url,source_name,excerpt
# SUPABASE_ARTICLES_FILTER=is_published=eq.true
# SUPABASE_ARTICLES_ORDER=created_at.desc

# --- GitHub Actions: social automation (`npm run automate` / MCP Run workflow) ---
# Comma- or space-separated list (default: tiktok). Allowed: tiktok, instagram, facebook, x (twitter → x).
# AUTOMATION_CHANNELS=tiktok,instagram,facebook,x
#
# Per-platform SocialAPI targets: internal account id **or** handle. Resolved via GET /accounts when possible; omit to use the first matching connected account for that platform.
# AUTOMATION_TIKTOK_ACCOUNT_ID=nextboyfriend_community
# AUTOMATION_INSTAGRAM_ACCOUNT_ID=
# AUTOMATION_FACEBOOK_ACCOUNT_ID=
# AUTOMATION_X_ACCOUNT_ID=
# Optional: set to true to log payload without POSTing
# AUTOMATION_DRY_RUN=false
# Skip Claude entirely (no Messages API). Same as: npm run automate:template
# AUTOMATION_TEMPLATE_COPY=false
# When Anthropic credits are depleted: automation uses template copy and emails you (Resend)
# RESEND_API_KEY=re_...          # https://resend.com — add as GitHub Actions secret for CI
# AUTOMATION_NOTIFY_EMAIL=david@dashworth.com
# AUTOMATION_EMAIL_FROM=Next Boyfriend <onboarding@resend.dev>   # use your verified domain in Resend for production
# AUTOMATION_HARVEST_LIMIT=8
# AUTOMATION_TRENDS_GEO=US
# AUTOMATION_CONTENT_SEED=optional-string-for-article-rotation
# Attach Pollinations image: downloads URL then POST /v1/media/upload → media_ids (SocialAPI ignores raw URLs).
# If false, post text-only (caption + hashtags).
# AUTOMATION_INCLUDE_MEDIA_URLS=true
